    "@remix-run/react": "2.17.5",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@remix-run/dev": "2.17.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "lefthook": "2.1.9",
    "remix-routes": "1.7.7",
