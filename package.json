    "@remix-run/react": "2.17.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@remix-run/dev": "2.17.4",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "concurrently": "9.2.1",
    "lefthook": "2.1.6",
    "remix-routes": "1.7.7",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "6.1.1"
